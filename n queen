def printSolution(board, N):

    for i in range(N):
        for j in range(N):

            print(board[i][j], end=" ")

        print()

    print()


# Function to check safe position
def isSafe(board, row, col, N):

    # Check left side row
    for i in range(col):

        if board[row][i] == 1:
            return False

    # Check upper diagonal
    i = row
    j = col

    while i >= 0 and j >= 0:

        if board[i][j] == 1:
            return False

        i -= 1
        j -= 1

    # Check lower diagonal
    i = row
    j = col

    while i < N and j >= 0:

        if board[i][j] == 1:
            return False

        i += 1
        j -= 1

    return True


# Recursive function
def solveNQUtil(board, col, N):

    # Base condition
    if col >= N:

        global solutionCount

        solutionCount += 1

        print("Solution", solutionCount)
        printSolution(board, N)

        return

    # Try every row
    for i in range(N):

        if isSafe(board, i, col, N):

            # Place queen
            board[i][col] = 1

            # Recursive call
            solveNQUtil(board, col + 1, N)

            # Backtracking
            board[i][col] = 0


# Main Program

N = int(input("Enter value of N: "))

board = [[0 for x in range(N)] for y in range(N)]

solutionCount = 0

solveNQUtil(board, 0, N)

if solutionCount == 0:
    print("No Solution Exists")

else:
    print("Total Solutions =", solutionCount)
