# Dijkstra Algorithm on 2D Grid

def dijkstra_grid(grid, start, end):

    rows = len(grid)
    cols = len(grid[0])

    # Distance matrix
    distance = [[float('inf')] * cols for _ in range(rows)]

    # Start position distance = 0
    distance[start[0]][start[1]] = 0

    visited = []

    while True:

        min_dist = float('inf')
        current = None

        # Find minimum distance cell
        for i in range(rows):

            for j in range(cols):

                if (i, j) not in visited and distance[i][j] < min_dist:

                    min_dist = distance[i][j]
                    current = (i, j)

        # Stop if no node found
        if current is None:
            break

        # Stop if end reached
        if current == end:
            break

        visited.append(current)

        x, y = current

        # Possible directions
        directions = [

            (-1, 0),  # Up
            (1, 0),   # Down
            (0, -1),  # Left
            (0, 1)    # Right

        ]

        # Visit neighbours
        for dx, dy in directions:

            nx = x + dx
            ny = y + dy

            # Check valid cell
            if 0 <= nx < rows and 0 <= ny < cols:

                new_dist = distance[x][y] + grid[nx][ny]

                if new_dist < distance[nx][ny]:

                    distance[nx][ny] = new_dist

    return distance[end[0]][end[1]]


# 2D Grid
grid = [

    [1, 2, 1],
    [4, 1, 3],
    [2, 1, 1]

]

# Start and End Positions
start = (0, 0)
end = (2, 2)

# Function Call
shortest_path = dijkstra_grid(grid, start, end)

print("Shortest Path Cost:", shortest_path)
