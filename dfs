# Graph using adjacency list
graph = {
    'P': ['Q', 'R', 'S'],
    'Q': ['P', 'R'],
    'R': ['P', 'Q', 'T'],
    'S': ['P'],
    'T': ['R']
}

visited = set()

def dfs(node):

    if node not in visited:

        print(node, end=" ")
        visited.add(node)

        for neighbor in graph[node]:
            dfs(neighbor)

# Function call
dfs('P')