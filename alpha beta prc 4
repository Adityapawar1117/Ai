def alphabeta(node, depth, alpha, beta, MaximizingPlayer):
    if depth == 0:
        return node
     
    if MaximizingPlayer:
        maxEval = float('-inf')

        for child in node:
            eval = alphabeta(child,depth - 1, alpha, beta, False)
            maxEval = max(maxEval,eval)
            alpha = max(alpha, eval)

            if alpha >= beta:
                break
        return maxEval
    
    else:
        minEval = float('inf')

        for child in node:
            eval = alphabeta(child,depth-1, alpha,beta,True)
            minEval = min(minEval,eval)
            beta = min(beta, eval)

            if alpha>= beta:
                break
        return minEval

game_tree = [
    [
        [3,5],[6,9]
    ],
    [
        [2,1],[0,-1]
    ]
]

optimal_solution = alphabeta(game_tree,3,float('-inf'),float('inf'),True)
print("Optimal Solution: ",optimal_solution)
